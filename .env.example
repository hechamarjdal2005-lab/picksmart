# PickSmart environment configuration
# Copy this file to `.env.local` and fill in real values.
# Anything prefixed NEXT_PUBLIC_ is exposed to the browser bundle.

# Supabase configuration
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Canonical site URL (used for metadata / Open Graph).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Base URL for outbound affiliate links ("View on Amazon" buttons).
# e.g. https://www.amazon.com/dp/PRODUCT_ID?tag=YOUR_AFFILIATE_TAG
NEXT_PUBLIC_AFFILIATE_BASE_URL="https://www.amazon.com"

# Amazon Associates tracking tag appended to affiliate links.
NEXT_PUBLIC_AFFILIATE_TAG="picksmart-20"

# Newsletter signup endpoint (server-side). Leave blank to disable.
NEWSLETTER_API_URL=""
